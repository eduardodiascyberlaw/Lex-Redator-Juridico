# ── Backend ──────────────────────────────────────────
PORT=3003
NODE_ENV=development
CORS_ORIGIN=http://localhost:5175

# ── Base de dados (PostgreSQL) ───────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/lex_redator?schema=public

# ── Anthropic (Claude) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_SONNET=claude-sonnet-4-5-20250514
CLAUDE_MODEL_HAIKU=claude-haiku-4-5-20251001

# ── Lex-Corpus API (RAG) ────────────────────────────
LEX_CORPUS_API_URL=http://localhost:3002
LEX_CORPUS_TIMEOUT_MS=15000

# ── RAG Config ───────────────────────────────────────
SEARCH_TOP_K=20
RAG_MAX_DOCUMENTS=8
RAG_MAX_CHUNKS_PER_DOC=2
